MONGO_URI=mongodb://admin:admin@mongo:27017
MONGO_DB_NAME=mydb
# For production (e.g. Upstash): set REDIS_URL to full URL (rediss://default:password@host:port)
# For local Docker: leave REDIS_URL empty and use REDIS_HOST=valkey, REDIS_PORT=6379
REDIS_URL=
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=
# Optional: for remote Redis (Upstash) – avoids timeouts, fewer health-check round-trips (seconds)
# REDIS_SOCKET_CONNECT_TIMEOUT=15
# REDIS_SOCKET_TIMEOUT=15
# REDIS_HEALTH_CHECK_INTERVAL=30
RQ_QUEUE_NAME=default
UPLOAD_ROOT=/mnt/uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
